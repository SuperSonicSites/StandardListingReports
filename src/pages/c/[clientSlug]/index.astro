---
import AppLayout from "../../../layouts/AppLayout.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import ErrorCard from "../../../components/ErrorCard.astro";
import Toast from "../../../components/Toast.astro";
import { readClient } from "../../../lib/storage";
import { takeFlash } from "../../../lib/flash";

const clientSlug = Astro.params.clientSlug ?? "";
let client;

try {
  client = await readClient(clientSlug);
} catch {
  Astro.response.status = 404;
}
const flash = takeFlash(Astro.cookies);
---

<AppLayout
  title={client ? `New report | ${client.name}` : "Client not found | Supersonic"}
  className="client-form-body"
>
  {
    client ? (
      <>
        <SiteHeader context={client.name} contextAccent={client.brand_accent} />
        <main class="client-workspace">
          <div class="co-hero reveal">
            <p class="eyebrow">Listing report</p>
            <h1>Create Listing Report</h1>
            <p>
              Paste your REALTOR.ca share link and pull. We find the listing, the
              matching posts, and the numbers — you just confirm and create the
              report.
            </p>
          </div>

          <form id="report-form" method="post" action="/api/snapshot" novalidate>
            <input type="hidden" name="client_slug" value={client.slug} />
            <input type="hidden" name="facebook_media_url" value="" />
            <input type="hidden" name="instagram_media_url" value="" />
            <input type="hidden" name="property_image_url" value="" />
            <input type="hidden" name="site_total_views" value="0" />
            <input type="hidden" name="website_source" value="manual" />
            <input type="hidden" name="facebook_source" value="manual" />
            <input type="hidden" name="instagram_source" value="manual" />
            <input type="hidden" name="start_date" value="" />
            <input type="hidden" name="end_date" value="" />

            {/* ===== 1. Intake ===== */}
            <section class="card co-section" data-pull-card>
              <div class="numbered-head">
                <span class="num">1</span>
                <div class="head-text">
                  <h2>Start here</h2>
                  <p>
                    Paste the REALTOR.ca share link and pull. Everything else
                    fills in below for you to confirm.
                  </p>
                </div>
              </div>

              <div class="field">
                <label class="field-label" for="coord-url">
                  REALTOR.ca Admin URL <span class="req">*</span>
                </label>
                <input
                  id="coord-url"
                  type="url"
                  name="realtor_admin_url"
                  placeholder="https://member.realtor.ca/Reports/ListingDestination/..."
                  aria-describedby="url-help"
                  autofocus
                />
                <p class="field-hint" id="url-help">
                  In REALTOR.ca, open your listing and click
                  <span class="share-pill">SHARE LISTING</span> (top-right). Send
                  the link to yourself, then paste it here.
                </p>
              </div>

              <div class="pull-strip">
                <div class="pull-status" aria-live="polite">
                  <span class="pull-dot" data-pull-dot aria-hidden="true" />
                  <div style="min-width: 0">
                    <strong data-pull-status>Ready to pull</strong>
                    <div class="detail" data-pull-detail>
                      Paste the REALTOR.ca link above, then pull — everything else
                      fills in for you to confirm.
                    </div>
                  </div>
                </div>
                <button
                  class="button primary"
                  type="button"
                  data-pull-trigger
                  style="min-width: 124px"
                >
                  Pull data
                </button>
              </div>

              {/* Post pickers — revealed after the pull. */}
              <div data-social-picker hidden>
                <div
                  class="reveal"
                  style="display: flex; flex-direction: column; gap: 16px; margin-top: 16px"
                >
                  <div class="field" data-notice-anchor="facebook">
                    <label class="field-label">Featured Facebook post</label>
                    <div style="display: flex; gap: 12px; align-items: flex-start">
                      <button
                        type="button"
                        class="post-thumb"
                        style="width: 76px; height: 76px; flex: none"
                        data-zoom="facebook"
                        aria-label="Enlarge Facebook post image"
                      >
                        <img data-media-preview="facebook" alt="Selected Facebook post image" hidden />
                        <span
                          class="thumb-badge"
                          style="background: #1877f2; font-weight: 800; font-size: 0.6rem"
                        >
                          f
                        </span>
                      </button>
                      <div style="flex: 1; min-width: 0">
                        <select data-candidate-select="facebook" aria-label="Featured Facebook post">
                          <option value="">Pull data to match posts…</option>
                        </select>
                      </div>
                    </div>
                  </div>

                  <div class="field" data-notice-anchor="instagram">
                    <label class="field-label">Featured Instagram post</label>
                    <div style="display: flex; gap: 12px; align-items: flex-start">
                      <button
                        type="button"
                        class="post-thumb"
                        style="width: 76px; height: 76px; flex: none"
                        data-zoom="instagram"
                        aria-label="Enlarge Instagram post image"
                      >
                        <img data-media-preview="instagram" alt="Selected Instagram post image" hidden />
                        <span
                          class="thumb-badge"
                          style="background: linear-gradient(45deg, #f09433, #dc2743, #bc1888)"
                        >
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none">
                            <rect x="4" y="4" width="16" height="16" rx="4.5" stroke="currentColor" stroke-width="2.4" />
                            <circle cx="12" cy="12" r="3.3" stroke="currentColor" stroke-width="2.4" />
                          </svg>
                        </span>
                      </button>
                      <div style="flex: 1; min-width: 0">
                        <select data-candidate-select="instagram" aria-label="Featured Instagram post">
                          <option value="">Pull data to match posts…</option>
                        </select>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            {/* ===== Review (revealed after the pull) ===== */}
            <div data-review-block hidden>
              <div id="coord-summary" class="card err-summary" role="alert" hidden>
                <h2 id="coord-summary-h" tabindex="-1" />
                <ul data-summary-list />
              </div>

              {/* Section 2 — Listing details */}
              <section class="card co-section reveal">
                <div class="numbered-head">
                  <span class="num">2</span>
                  <div class="head-text">
                    <h2>Listing details</h2>
                    <p>Pulled from REALTOR.ca — edit only if a value is wrong.</p>
                  </div>
                </div>
                <div class="section-fields">
                  <div class="field">
                    <label class="field-label" for="addr">Address <span class="req">*</span></label>
                    <input id="addr" name="address" placeholder="Pulled from REALTOR.ca" data-field="address" />
                    <p class="err-note" data-err-for="address" hidden />
                  </div>
                  <div class="field">
                    <label class="field-label" for="mls">MLS&reg; number</label>
                    <input id="mls" name="mls_number" placeholder="Pulled from REALTOR.ca" />
                  </div>

                  <div class="field" data-period-pill>
                    <span class="field-label">Report period</span>
                    <div
                      style="display: inline-flex; align-items: center; gap: 8px; align-self: flex-start; background: var(--ss-bg); border: 1px solid var(--ss-border); border-radius: var(--ss-radius-sm); padding: 10px 14px; min-height: 44px"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <rect x="4" y="5" width="16" height="16" rx="2" stroke="#64748b" stroke-width="1.6" />
                        <path d="M4 9h16M8 3v4M16 3v4" stroke="#64748b" stroke-width="1.6" stroke-linecap="round" />
                      </svg>
                      <span style="font-weight: 600; font-size: 0.88rem" data-period-text>
                        First day on market &rarr; today
                      </span>
                    </div>
                    <p class="field-hint">Set automatically from the listing&rsquo;s first day on market.</p>
                  </div>

                  <div class="field" data-period-fallback hidden>
                    <div class="notice" role="status">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                        <path d="M12 9v4m0 4h.01M10.3 3.9 2.4 18a2 2 0 0 0 1.7 3h15.8a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      We couldn&rsquo;t read the listing date. Set the reporting window below.
                    </div>
                    <div class="two-up" style="margin-top: 8px">
                      <label class="field" style="gap: 6px">
                        <span class="field-label">First day on market</span>
                        <input class="amber" type="date" data-period-start />
                      </label>
                      <label class="field" style="gap: 6px">
                        <span class="field-label">End date</span>
                        <input class="amber" type="date" data-period-end />
                      </label>
                    </div>
                  </div>

                  <div class="field" data-notice-anchor="listing">
                    <label class="field-label" for="listing-url">
                      Website URL <span class="req">*</span>
                      <span class="info-wrap" data-info="listing" hidden>
                        <button type="button" class="info-dot" data-tip-toggle="listing" style="width: 18px; height: 18px" />
                        <span class="tooltip" data-tip="listing" hidden />
                      </span>
                    </label>
                    <input id="listing-url" type="url" name="listing_url" placeholder="https://…" data-field="listing_url" />
                    <p class="err-note" data-err-for="listing_url" hidden />
                  </div>
                </div>
              </section>

              {/* Section 3 — Performance */}
              <section class="card co-section reveal">
                <div class="numbered-head">
                  <span class="num">3</span>
                  <div class="head-text">
                    <h2>Performance</h2>
                    <p>Pulled numbers — review and correct anything that looks off.</p>
                  </div>
                </div>
                <div class="perf-stack">
                  {/* Website */}
                  <div class="rail-card" data-rail="website" data-fold="website" data-notice-anchor="website" style="box-shadow: none">
                    <div class="perf-metric-row">
                      <div style="min-width: 180px">
                        <div class="co-card-title">
                          <h3>Website analytics</h3>
                          <span class="info-wrap" data-info="website" hidden>
                            <button type="button" class="info-dot" data-tip-toggle="website" />
                            <span class="tooltip" data-tip="website" hidden />
                          </span>
                        </div>
                        <p class="co-card-desc">Listing traffic for the reporting window.</p>
                      </div>
                      <div style="text-align: right">
                        <input class="import-metric-input metric-big" type="number" inputmode="numeric" min="0" name="website_views" value="0" aria-label="Website listing page views" data-field="website_views" />
                        <div class="metric-cap">listing page views</div>
                      </div>
                    </div>
                    <p class="err-note" data-err-for="website_views" hidden style="margin-top: 8px" />
                  </div>

                  {/* REALTOR.ca */}
                  <div class="rail-card" data-rail="realtor" data-notice-anchor="realtor" style="box-shadow: none">
                    <div class="realtor-grid">
                      <div style="min-width: 0">
                        <div class="co-card-title">
                          <h3>REALTOR.ca performance</h3>
                          <span class="info-wrap" data-info="realtor" hidden>
                            <button type="button" class="info-dot" data-tip-toggle="realtor" />
                            <span class="tooltip" data-tip="realtor" hidden />
                          </span>
                        </div>
                        <p class="co-card-desc">Listing views and days on market for the reporting window.</p>
                        <div style="display: flex; gap: 12px; margin-top: 12px">
                          <div class="stat-tile" style="flex: 1">
                            <div class="stat-label">Total views</div>
                            <input class="import-metric-input" type="number" inputmode="numeric" min="0" name="realtor_listing_views" value="0" aria-label="Total views" data-field="realtor_listing_views" />
                          </div>
                          <div class="stat-tile" style="flex: 1">
                            <div class="stat-label">Days on market</div>
                            <input class="import-metric-input" type="number" inputmode="numeric" min="0" name="days_on_market" value="0" aria-label="Days on market" data-field="days_on_market" />
                          </div>
                        </div>
                      </div>
                      <div style="min-width: 0">
                        <div class="tile-label">Cover photo</div>
                        <div class="cover-tile" data-cover-tile aria-label="Listing cover photo">
                          <img data-media-preview="realtor" alt="Listing cover photo (appears on the report cover)" hidden />
                          <svg width="42" height="42" viewBox="0 0 24 24" fill="none" data-cover-icon>
                            <path d="M4 11 12 4l8 7" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M6 10v9h12v-9" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </div>
                        <div class="cover-empty" data-cover-empty hidden>No cover photo captured</div>
                        <p style="font-size: 0.72rem; color: var(--ss-muted); margin: 6px 0 0">
                          This image appears on the report cover.
                        </p>
                      </div>
                    </div>
                  </div>

                  {/* Social */}
                  <div class="rail-card" data-fold="social" data-notice-anchor="social" style="border-left-color: var(--ss-border); box-shadow: none">
                    <div class="co-card-title">
                      <h3>Social performance</h3>
                      <span class="info-wrap" data-info="social" hidden>
                        <button type="button" class="info-dot" data-tip-toggle="social" />
                        <span class="tooltip" data-tip="social" hidden />
                      </span>
                    </div>
                    <p class="co-card-desc">
                      Views for the featured posts. Captions land verbatim on the report.
                    </p>

                    <div class="social-row" data-rail="facebook">
                      <div style="display: flex; flex-direction: column; gap: 10px; min-width: 0">
                        <div class="social-net">
                          <span class="net-ico" style="background: #1877f2; font-weight: 800; font-size: 0.7rem">f</span>
                          Facebook
                        </div>
                        <input name="facebook_post_url" placeholder="Post URL" aria-label="Facebook post URL" style="min-height: 38px" />
                        <div class="field" style="gap: 4px">
                          <textarea name="facebook_caption" maxlength="300" rows="2" aria-label="Facebook caption — appears on the report" placeholder="Caption — appears on the report" data-counter-src="facebook" />
                          <div class="counter" data-counter="facebook">0 / 300</div>
                        </div>
                        <div class="stat-tile">
                          <div class="stat-label">Views</div>
                          <input class="import-metric-input" type="number" inputmode="numeric" min="0" name="facebook_views" value="0" aria-label="Facebook views" data-field="facebook_views" />
                        </div>
                      </div>
                      <div style="min-width: 0">
                        <div class="tile-label">Post image</div>
                        <button type="button" class="post-thumb" data-zoom="facebook" aria-label="Enlarge Facebook post image">
                          <img data-review-media="facebook" alt="Facebook post image" hidden />
                          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" data-thumb-icon style="position: absolute; inset: 0; margin: auto; opacity: 0.85">
                            <path d="M4 11 12 4l8 7" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M6 10v9h12v-9" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                          <span class="thumb-badge" style="background: #1877f2; font-weight: 800; font-size: 0.68rem">f</span>
                        </button>
                      </div>
                    </div>

                    <div class="social-row" data-rail="instagram">
                      <div style="display: flex; flex-direction: column; gap: 10px; min-width: 0">
                        <div class="social-net">
                          <span class="net-ico" style="background: linear-gradient(45deg, #f09433, #dc2743, #bc1888)">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none">
                              <rect x="4" y="4" width="16" height="16" rx="4.5" stroke="currentColor" stroke-width="2" />
                              <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="2" />
                            </svg>
                          </span>
                          Instagram
                        </div>
                        <input name="instagram_post_url" placeholder="Post URL" aria-label="Instagram post URL" style="min-height: 38px" />
                        <div class="field" style="gap: 4px">
                          <textarea name="instagram_caption" maxlength="300" rows="2" aria-label="Instagram caption — appears on the report" placeholder="Caption — appears on the report" data-counter-src="instagram" />
                          <div class="counter" data-counter="instagram">0 / 300</div>
                        </div>
                        <div class="stat-tile">
                          <div class="stat-label">Views</div>
                          <input class="import-metric-input" type="number" inputmode="numeric" min="0" name="instagram_views" value="0" aria-label="Instagram views" data-field="instagram_views" />
                        </div>
                      </div>
                      <div style="min-width: 0">
                        <div class="tile-label">Post image</div>
                        <button type="button" class="post-thumb" data-zoom="instagram" aria-label="Enlarge Instagram post image">
                          <img data-review-media="instagram" alt="Instagram post image" hidden />
                          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" data-thumb-icon style="position: absolute; inset: 0; margin: auto; opacity: 0.85">
                            <path d="M4 11 12 4l8 7" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M6 10v9h12v-9" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                          <span class="thumb-badge" style="background: linear-gradient(45deg, #f09433, #dc2743, #bc1888)">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none">
                              <rect x="4" y="4" width="16" height="16" rx="4.5" stroke="currentColor" stroke-width="2.4" />
                              <circle cx="12" cy="12" r="3.3" stroke="currentColor" stroke-width="2.4" />
                            </svg>
                          </span>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </section>

              {/* Section 4 — Showings & notes */}
              <section class="card co-section reveal">
                <div class="numbered-head">
                  <span class="num">4</span>
                  <div class="head-text">
                    <h2>Showings &amp; notes</h2>
                    <p>The one number we can&rsquo;t pull, plus any seller-facing note.</p>
                  </div>
                </div>
                <div class="section-fields">
                  <div style="display: flex; gap: 16px; flex-wrap: wrap; align-items: flex-end">
                    <div class="field" style="max-width: 200px">
                      <label class="field-label" for="showings">Showings <span class="req">*</span></label>
                      <input id="showings" type="number" inputmode="numeric" min="0" name="showings" placeholder="0" style="font-weight: 600" data-field="showings" />
                      <p class="err-note" data-err-for="showings" hidden />
                    </div>
                    <label class="toggle-row">
                      <input type="checkbox" name="hide_showings" value="yes" />
                      Do not display showings on the report
                    </label>
                  </div>
                  <div class="field">
                    <label class="field-label" for="notes">Seller-facing note</label>
                    <textarea id="notes" name="notes" maxlength="600" rows="4" placeholder="Optional — a short note the seller sees on the report." data-counter-src="notes" style="min-height: 88px" />
                    <div class="counter" data-counter="notes">0 / 600</div>
                    <label class="toggle-row">
                      <input type="checkbox" name="hide_notes" value="yes" />
                      Do not display notes on the report
                    </label>
                  </div>
                </div>
              </section>

              {/* Submit */}
              <div class="card co-submit reveal">
                <label class="toggle-row" style="align-items: flex-start; max-width: 520px">
                  <input type="checkbox" name="approved" value="yes" data-approval style="margin-top: 2px" />
                  <span>
                    <span style="font-weight: 600; color: var(--ss-ink); display: block; margin-bottom: 2px">
                      Review and approve
                    </span>
                    <span style="font-size: 0.84rem; color: var(--ss-text-soft); line-height: 1.4">
                      I have reviewed the numbers, captions, images, and notes above.
                    </span>
                  </span>
                </label>
                <div class="co-submit-right">
                  <button class="button primary" type="submit" data-submit-button disabled style="min-width: 172px">
                    Create Report
                  </button>
                  <span style="font-size: 0.78rem; color: var(--ss-muted)" data-approval-hint>
                    Check the box to enable.
                  </span>
                </div>
              </div>
            </div>
          </form>

          {/* Pull loading modal */}
          <div
            class="modal-scrim"
            data-pull-modal
            role="dialog"
            aria-modal="true"
            aria-label="Pulling your data"
            hidden
          >
            <div class="modal-card" style="width: min(400px, 100%); text-align: center; display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 30px 28px">
              <span class="pull-spinner" aria-hidden="true" />
              <div aria-live="polite" style="min-height: 52px">
                <div style="font-weight: 700; font-size: 1rem; color: var(--ss-ink); margin-bottom: 5px" data-pull-stage>
                  Opening your REALTOR.ca listing…
                </div>
                <p style="font-size: 0.85rem; color: var(--ss-text-soft); margin: 0; line-height: 1.5">
                  Reading REALTOR.ca stats, matching Facebook/Instagram posts, and
                  website analytics. This can take up to a minute.
                </p>
              </div>
              <div style="width: 100%; height: 6px; border-radius: 999px; background: var(--ss-bg); overflow: hidden">
                <div data-pull-progress style="height: 100%; background: var(--ss-accent); border-radius: 999px; width: 8%; transition: width 0.4s ease" />
              </div>
            </div>
          </div>

          {/* Image zoom modal */}
          <div class="modal-scrim" data-zoom-modal role="dialog" aria-modal="true" aria-label="Post image preview" style="z-index: 85" hidden>
            <div class="zoom-card" data-zoom-card>
              <div class="zoom-media">
                <img data-zoom-img alt="Post image" />
                <span style="position: absolute; top: 12px; left: 12px; display: inline-flex; align-items: center; gap: 6px; background: rgba(13,21,34,.5); color: #fff; border-radius: var(--ss-radius-pill); padding: 4px 11px; font-size: 0.75rem; font-weight: 600" data-zoom-platform>
                  Facebook post
                </span>
                <button type="button" data-zoom-close aria-label="Close preview" style="position: absolute; top: 12px; right: 12px; width: 32px; height: 32px; border-radius: 50%; border: none; background: rgba(13,21,34,.5); color: #fff; cursor: pointer; font-size: 1.15rem; line-height: 1">
                  ×
                </button>
              </div>
              <div style="padding: 18px 20px">
                <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 8px">
                  <span style="font-weight: 700; font-size: 0.9rem; color: var(--ss-ink)">Post preview</span>
                  <span style="font-size: 0.82rem; color: var(--ss-muted)"><span data-zoom-views>0</span> views</span>
                </div>
                <p style="font-size: 0.9rem; color: var(--ss-text-soft); line-height: 1.6; margin: 0" data-zoom-caption />
                <p style="font-size: 0.78rem; color: var(--ss-muted); margin: 12px 0 0; font-style: italic">
                  This is the image and caption that appear on the report.
                </p>
              </div>
            </div>
          </div>
        </main>

        <Toast message={flash} />

        <script>
          import { initCoordinatorForm } from "../../../scripts/coordinator-form";
          initCoordinatorForm();
        </script>
      </>
    ) : (
      <>
        <SiteHeader />
        <ErrorCard
          eyebrow="Missing client"
          title="Client not found"
          reason={`No client profile exists for "${clientSlug}". The link may be out of date.`}
          actions={[{ label: "Back to clients", href: "/", variant: "primary" }]}
        />
      </>
    )
  }
</AppLayout>
