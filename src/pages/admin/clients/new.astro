---
import AppLayout from "../../../layouts/AppLayout.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import ClientForm from "../../../components/ClientForm.astro";
---

<AppLayout title="Create Client | Seller Report Generator" className="app-body">
  <SiteHeader>
    <a class="nav-link" href="/">All clients</a>
  </SiteHeader>

  <main class="form-shell">
    <header class="page-header">
      <a class="back-link" href="/">&larr; Back to clients</a>
      <p class="eyebrow">Client setup</p>
      <h1>Create client</h1>
      <p>
        This writes a JSON profile to <code>data/clients</code> and creates the
        report form endpoint for that client.
      </p>
    </header>

    <ClientForm />
  </main>
</AppLayout>
