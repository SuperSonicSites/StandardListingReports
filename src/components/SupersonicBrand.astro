---
// Supersonic brand lockup: paper-plane mark plus lowercase wordmark.
// The wordmark is real text (not SVG) so it always renders in the local Inter.
type Props = {
  size?: number;
  wordmark?: boolean;
};

const { size = 26, wordmark = true } = Astro.props;
const markHeight = Math.round(size * (40 / 48));
---

<span class="ss-brand">
  <svg
    class="ss-brand-mark"
    width={size}
    height={markHeight}
    viewBox="0 0 48 40"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden={wordmark ? "true" : undefined}
    role={wordmark ? undefined : "img"}
    aria-label={wordmark ? undefined : "Supersonic"}
  >
    <path fill="#0d1522" d="M0.5 24.5C8.5 24 16 21.6 22.6 17.3l2 2.9C17.4 24.8 9.3 27 0.5 27Z" />
    <path fill="#0d1522" d="M4 32.5c6.4-.5 12.2-2.3 17.3-5.5l1.6 2.5C17.4 32.9 11.2 34.6 4 34.6Z" />
    <path fill="#29abe2" d="M46 1.5 13.5 20.5l15.5 3Z" />
    <path fill="#0f8ac4" d="M46 1.5 29 23.5 25 37Z" />
  </svg>
  {wordmark && <span class="ss-brand-word">supersonic<span class="ss-brand-reg">®</span></span>}
</span>
