---
import AppLayout from "../../../../layouts/AppLayout.astro";
import SiteHeader from "../../../../components/SiteHeader.astro";
import ClientForm from "../../../../components/ClientForm.astro";
import ErrorCard from "../../../../components/ErrorCard.astro";
import { readClient } from "../../../../lib/storage";

const clientSlug = Astro.params.clientSlug ?? "";
let client;

try {
  client = await readClient(clientSlug);
} catch {
  Astro.response.status = 404;
}
---

<AppLayout
  title={client ? `Edit ${client.name} | Supersonic` : "Client not found | Supersonic"}
  className="app-body"
>
  <SiteHeader context={client?.name} contextAccent={client?.brand_accent}>
    <a class="nav-link" href="/">All clients</a>
  </SiteHeader>

  {
    client ? (
      <main class="app-shell">
        <header class="page-header">
          <a class="back-link" href="/">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path
                d="M15 6l-6 6 6 6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            Back to clients
          </a>
          <p class="eyebrow">Client setup</p>
          <h1>Edit client</h1>
          <p>
            Update this client&rsquo;s brand and access. Reports you&rsquo;ve
            already generated keep the branding they were created with — changes
            here only affect new reports.
          </p>
        </header>

        <ClientForm client={client} />
      </main>
    ) : (
      <ErrorCard
        eyebrow="Missing client"
        title="Client not found"
        reason={`We couldn't find a client called "${clientSlug}". It may have been deleted, or the link might be out of date.`}
        actions={[
          { label: "Back to clients", href: "/", variant: "primary" },
          {
            label: "Create a new client",
            href: "/admin/clients/new",
            variant: "ghost"
          }
        ]}
      />
    )
  }
</AppLayout>
