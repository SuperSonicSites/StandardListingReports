---
import "../styles/global.css";

type Props = {
  title?: string;
  className?: string;
};

const { title = "Seller Report Generator", className = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class={className}>
    <slot />
  </body>
</html>
