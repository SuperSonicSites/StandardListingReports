# Meta System User token (master Business Manager). Server-side only, never exposed to the browser.
META_SYSTEM_USER_TOKEN=

# Rybbit org-scoped API key. Server-side only.
RYBBIT_API_KEY=

# Rybbit API base URL. Defaults to https://app.rybbit.io if unset.
RYBBIT_API_URL=

# Brave Search API key. Enables auto-finding the listing page on the client's own website
# by MLS#/address (fills the Website URL). Optional — without it the Website URL is entered
# manually. Server-side only. Free tier allows ~1 request/second.
BRAVE_API_KEY=

# Local Chrome/Edge executable for PDF generation, if not in a standard install location.
CHROME_PATH=

# Agency password for the admin area (home, client create/edit). Also unlocks every
# client workspace. Required — without it the admin pages are unreachable (fail closed).
ADMIN_PASSWORD=

# Set to 1 to make "Pull data" return fabricated demo numbers (source: "mock") when no
# API credentials are configured. Leave unset in production: without it, a missing
# credential degrades to a "configure or enter manually" warning instead of fake data.
DEMO_MODE=

# NOTE: .env is only read by `npm run dev` (Vite loads it at startup — restart after edits).
# The built server (`npm run start` / `npm run preview`) does NOT load .env; set real
# environment variables on the host (e.g. Railway service variables) instead.
