---
import AppLayout from "../layouts/AppLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { listClients } from "../lib/storage";

const clients = await listClients();
---

<AppLayout title="Seller Report Generator | Supersonic" className="app-body">
  <SiteHeader>
    <a class="nav-link" href="/admin/clients/new">New client</a>
  </SiteHeader>

  <main class="app-shell">
    <section class="app-hero">
      <div>
        <p class="eyebrow">Seller report engine</p>
        <h1>Seller Report Generator</h1>
        <p>
          Capture report details, freeze the numbers into a snapshot, and
          render a branded seller report ready to download as a PDF.
        </p>
      </div>
      <div class="hero-actions">
        <a class="button primary" href="/admin/clients/new">Create client</a>
      </div>
    </section>

    <section class="panel">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Clients</p>
          <h2>Report endpoints</h2>
        </div>
        <span class="count-badge">{clients.length} {clients.length === 1 ? "client" : "clients"}</span>
      </div>

      {clients.length > 0 ? (
        <div class="client-grid">
          {clients.map((client) => (
            <article class="client-card">
              <div class="client-card-logo">
                <img src={client.logo_url} alt={`${client.name} logo`} />
              </div>
              <div>
                <h3>{client.name}</h3>
                <p>{client.footer_text}</p>
                <div class="client-card-links">
                  <a class="button secondary sm" href={`/c/${client.slug}/`}>Open report form</a>
                  <a class="button ghost sm" href={`/admin/clients/${client.slug}/edit`}>Edit</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <strong>No clients yet</strong>
          <p>Create your first client profile to get a branded report form endpoint.</p>
          <a class="button primary" href="/admin/clients/new">Create client</a>
        </div>
      )}
    </section>
  </main>
</AppLayout>
